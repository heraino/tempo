# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it's already in .gitignore.

# Neon Postgres connection string
# Get this from: neon.tech → your project → Dashboard → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret — used to sign session cookies and tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Google OAuth credentials (optional — Resend magic-link is the primary provider)
# Get these from: console.cloud.google.com → your project → Credentials → OAuth 2.0 Client IDs
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend API key for sending magic-link emails
# Get this from: resend.com → API Keys
AUTH_RESEND_KEY=""

# Vercel Blob — immutable raw FIT file storage (required from Phase 2)
# Get this from: vercel.com → your project → Storage → Blob → Create
BLOB_READ_WRITE_TOKEN=""

# Nebius AI API — LLM coaching analysis (required from Phase 6)
# Uses the OpenAI-compatible API. Get key from: studio.nebius.ai
NEBIUS_API_KEY=""
NEBIUS_BASE_URL="https://api.studio.nebius.ai/v1/"
NEBIUS_MODEL="meta-llama/Meta-Llama-3.1-70B-Instruct"

# Analytics version — bumped when deterministic metric formulas change.
# Allows coaching analyses to be traced to the exact calculation version.
ANALYTICS_VERSION="1"
